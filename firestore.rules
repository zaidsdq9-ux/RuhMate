rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Users — readable only by self. All writes go through API routes (Admin SDK bypasses rules).
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow write: if false;
    }

    // Profiles — own profile fully readable by self. Other profiles' contact + income fields
    // must never be reached via client SDK — feed/detail endpoints return them only when unlocked.
    // Client-side reads on other profiles are blocked here; the API serves them with a scrubbed projection.
    match /profiles/{profileId} {
      allow read: if isSelf(profileId);
      allow write: if false;
    }

    // Everything else — server-only.
    match /unlocks/{id}          { allow read, write: if false; }
    match /transactions/{id}     { allow read, write: if false; }
    match /point_packs/{id}      { allow read, write: if false; }
    match /settings/{id}         { allow read, write: if false; }
    match /counters/{id}         { allow read, write: if false; }
    match /audit_log/{id}        { allow read, write: if false; }
    match /reports/{id}          { allow read, write: if false; }
    match /rate_limits/{id}      { allow read, write: if false; }
  }
}
